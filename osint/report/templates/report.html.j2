<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 24px; }
    h1, h2 { margin-bottom: 8px; }
    .subject { margin-bottom: 16px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
    .card { border: 1px solid #ddd; border-radius: 8px; padding: 8px; }
    .card img { max-width: 100%; height: auto; border-radius: 4px; }
    .meta { font-size: 12px; color: #555; }
    .match-true { background: #e6ffed; }
    .match-false { background: #fff0f0; }
  </style>
</head>
<body>
  <h1>{{ title }}</h1>

  <h2>Subjects</h2>
  <div>
    {% for s in subjects %}
      <div class="subject">
        <strong>{{ s.id }}</strong>
        <div>Names: {{ s.names|join(', ') }}</div>
        <div>Usernames: {{ s.usernames|join(', ') }}</div>
      </div>
    {% endfor %}
  </div>

  <h2>Collected Images</h2>
  <div class="grid">
    {% for im in images %}
      <div class="card {{ 'match-true' if im.is_match else 'match-false' }}">
        <div class="meta">Subject: {{ im.subject_id }}</div>
        <img src="{{ im.path }}" alt="image" />
        <div class="meta">Match: {{ im.is_match }} ({{ '%.2f' % im.confidence }})</div>
        {% if im.title %}<div class="meta">Title: {{ im.title }}</div>{% endif %}
        <div class="meta"><a href="{{ im.source_url }}" target="_blank">Source</a></div>
      </div>
    {% endfor %}
  </div>

  <p style="margin-top:24px; font-size: 12px; color:#555">Generated by OSINT Connection Analysis Pipeline</p>
</body>
</html>