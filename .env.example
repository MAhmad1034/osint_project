# Copy to .env and fill as needed
# Core
ENV_NAME=dev
DATA_DIR=data
REPORTS_DIR=reports

# Optional: enable facial recognition modules (must be true AND keys present)
ALLOW_FACIAL_RECOGNITION=false

# Optional API keys (leave blank if unused)
BING_SEARCH_API_KEY=
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0
SERPAPI_API_KEY=
FACECHECK_API_KEY=
AZURE_FACE_ENDPOINT=
AZURE_FACE_KEY=